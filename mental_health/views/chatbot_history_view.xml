<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_chatbot_history_tree" model="ir.ui.view">
        <field name="name">chatbot.history.tree</field>
        <field name="model">chatbot.history</field>
        <field name="arch" type="xml">
            <tree>
                <field name="create_date"/>
                <field name="session_id"/>
                <field name="user_id"/>
                <field name="user_message"/>
                <field name="bot_response"/>
            </tree>
        </field>
    </record>

</odoo>