<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_chatbot_config_form" model="ir.ui.view">
        <field name="name">chatbot.config.form</field>
        <field name="model">chatbot.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="api_key" password="True"/>
                        <field name="model_name" placeholder="gemini-2.5-flash"/>
                        <field name="temperature"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_chatbot_config_tree" model="ir.ui.view">
        <field name="name">chatbot.config.tree</field>
        <field name="model">chatbot.config</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="model_name"/>
                <field name="temperature"/>
            </tree>
        </field>
    </record>

</odoo>