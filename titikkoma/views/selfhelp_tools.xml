<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="selfhelp_tools_page" name="Self-Help Tools">
        <t t-call="website.layout">

            <link rel="stylesheet" href="/titikkoma/static/src/css/titikkoma.css"/>

            <div class="dashboard">

                <t t-call="titikkoma.shared_sidebar">
                    <t t-set="active_menu" t-value="'selfhelp'"/>
                </t>

                <!-- MAIN CONTENT -->
                <main class="main-content" id="mainContent">

                    <!-- PAGE HEADER -->
                    <div class="topbar">
                        <div class="welcome">
                            <h1>Self-Help Tools</h1>
                            <p>Latihan ringan untuk menenangkan pikiran.</p>
                        </div>
                    </div>

                    <!-- CARD GRID -->
                    <div class="sht-grid">

                        <!-- Card: Tips Self-Help -->
                        <a href="/blog/self-help-3" class="sht-card sht-card--blue">
                            <div class="sht-card__body">
                                <h2 class="sht-card__title">Tips Self-Help</h2>
                                <p class="sht-card__desc">Temukan artikel yang tepat untukmu.</p>
                            </div>
                            <div class="sht-card__illustration">
                                <i class="fa fa-mobile fa-4x"/>
                            </div>
                        </a>

                        <!-- Card: Journaling -->
                        <a href="/journaling/list" class="sht-card sht-card--purple">
                            <div class="sht-card__body">
                                <h2 class="sht-card__title">Journaling</h2>
                                <p class="sht-card__desc">Ungkapkan pikiran dan perasaanmu dengan bebas.</p>
                            </div>
                            <div class="sht-card__illustration">
                                <i class="fa fa-book fa-4x"/>
                            </div>
                        </a>

                    </div>

                </main>

            </div>

            <script>
                function toggleSidebar() {
                    const sidebar = document.getElementById("sidebar");
                    const mainContent = document.getElementById("mainContent");
                    sidebar.classList.toggle("collapsed");
                    mainContent.classList.toggle("expanded");
                }
            </script>

        </t>
    </template>
</odoo>