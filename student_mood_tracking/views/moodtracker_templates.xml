<odoo>
    <record id="view_mood_tracking_tree" model="ir.ui.view">
        <field name="name">student.mood.tracking.tree</field>
        <field name="model">student.mood.tracking</field>
        <field name="arch" type="xml">
            <tree string="Riwayat Mood" decoration-danger="mood_level == '1'" decoration-success="mood_level == '5'">
                <field name="date"/>
                <field name="student_id"/>
                <field name="mood_level"/>
                <field name="note"/>
            </tree>
        </field>
    </record>

    <record id="view_mood_tracking_graph" model="ir.ui.view">
        <field name="name">student.mood.tracking.graph</field>
        <field name="model">student.mood.tracking</field>
        <field name="arch" type="xml">
            <graph string="Tren Emosi Mahasiswa" type="line">
                <field name="date" interval="day"/>
                <field name="mood_level" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_student_mood_tracking" model="ir.actions.act_window">
        <field name="name">Mood Tracking</field>
        <field name="res_model">student.mood.tracking</field>
        <field name="view_mode">tree,form,graph</field>
    </record>

    <menuitem id="menu_mood_root" name="Mood Tracker" sequence="10"/>
    <menuitem id="menu_mood_entry" name="Catat Mood" parent="menu_mood_root" action="action_student_mood_tracking"/>
</odoo>
