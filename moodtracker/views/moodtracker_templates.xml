<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="moodtracker_page" name="Halaman Mood Tracker">
        <t t-call="website.layout">
            <div class="dashboard">

                <!-- SIDEBAR NAVIGATION -->
                <aside class="sidebar" id="sidebar">

                    <img src="/titikkoma/static/src/img/titikkomalogo1.png" alt="Titik Koma" class="logo"/>

                    <nav class="menu" style="margin-top: 30px;">

                        <div class="menu-title">Menu Utama</div>

                        <a href="/" class="menu-item">
                            <span class="icon">🏠</span>
                            <span>Beranda</span>
                        </a>

                        <a href="/assessment/retry/4591d5f4-b6f7-4991-aab7-9fdae2847b7e" class="menu-item">
                            <span class="icon">📋</span>
                            <span>Self Assessment</span>
                        </a>

                        <a href="/mood-tracker" class="menu-item active">
                            <span class="icon">📊</span>
                            <span>Mood Tracker</span>
                        </a>

                        <div class="menu-title" style="margin-top: 30px;">Dukungan</div>

                        <a href="/self-help-tools" class="menu-item">
                            <span class="icon">📚</span>
                            <span>Self-Help Tools</span>
                        </a>

                        <a href="/chatbot" class="menu-item">
                            <span class="icon">🤖</span>
                            <span>Chatbot AI</span>
                        </a>

                        <a href="/konseling" class="menu-item">
                            <span class="icon">💬</span>
                            <span>Konseling</span>
                        </a>

                    </nav>

                    <a href="/web/session/logout" class="menu-item logout-btn">
                        <span class="icon">⏻</span>
                        <span>Logout</span>
                    </a>

                </aside>

                <!-- Main -->
                <main class="main-content" id="mainContent">

                    <div class="mt-header">
                        <h1>Mood Tracker</h1>
                        <p>Pantau dan catat perasaanmu setiap hari.</p>
                    </div>

                    <!-- Pilih Mood -->
                    <div class="mt-section">
                        <h2 class="mt-section-title">Bagaimana perasaanmu hari ini?</h2>
                        <form action="/mood-tracker/simpan" method="POST">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div class="mt-mood-grid">
                                <label class="mt-mood-btn" t-att-class="'mt-mood-btn' + (' selected' if mood_hari_ini and mood_hari_ini.mood == 'luar_biasa' else '')">
                                    <input type="radio" name="mood" value="luar_biasa" style="display:none"/>
                                    <span class="mt-emoji">😄</span>
                                    <span class="mt-mood-label">Luar Biasa</span>
                                </label>
                                <label class="mt-mood-btn" t-att-class="'mt-mood-btn' + (' selected' if mood_hari_ini and mood_hari_ini.mood == 'baik' else '')">
                                    <input type="radio" name="mood" value="baik" style="display:none"/>
                                    <span class="mt-emoji">😊</span>
                                    <span class="mt-mood-label">Baik</span>
                                </label>
                                <label class="mt-mood-btn" t-att-class="'mt-mood-btn' + (' selected' if mood_hari_ini and mood_hari_ini.mood == 'buruk' else '')">
                                    <input type="radio" name="mood" value="buruk" style="display:none"/>
                                    <span class="mt-emoji">😔</span>
                                    <span class="mt-mood-label">Buruk</span>
                                </label>
                                <label class="mt-mood-btn" t-att-class="'mt-mood-btn' + (' selected' if mood_hari_ini and mood_hari_ini.mood == 'sangat_buruk' else '')">
                                    <input type="radio" name="mood" value="sangat_buruk" style="display:none"/>
                                    <span class="mt-emoji">😞</span>
                                    <span class="mt-mood-label">Sangat Buruk</span>
                                </label>
                            </div>
                            <button type="submit" class="mt-save-btn">Simpan Mood Hari Ini</button>
                        </form>
                    </div>

                    <!-- Statistik -->
                    <div class="mt-section">
                        <h2 class="mt-section-title">Statistik Minggu Ini</h2>
                        <div class="mt-stats-grid">
                            <div class="mt-stat-box">
                                <div class="mt-stat-num" t-esc="total"/>
                                <div class="mt-stat-lbl">Hari Tercatat</div>
                            </div>
                            <div class="mt-stat-box">
                                <div class="mt-stat-num">
                                    <t t-if="mood_dominan == 'luar_biasa'">😄</t>
                                    <t t-elif="mood_dominan == 'baik'">😊</t>
                                    <t t-elif="mood_dominan == 'buruk'">😔</t>
                                    <t t-elif="mood_dominan == 'sangat_buruk'">😞</t>
                                    <t t-else="">—</t>
                                </div>
                                <div class="mt-stat-lbl">Mood Dominan</div>
                            </div>
                            <div class="mt-stat-box">
                                <div class="mt-stat-num" t-esc="str(persen_positif) + '%'"/>
                                <div class="mt-stat-lbl">Mood Positif</div>
                            </div>
                        </div>
                    </div>

                    <!-- Riwayat -->
                    <div class="mt-section">
                        <h2 class="mt-section-title">Riwayat Mood</h2>
                        <t t-if="history">
                            <div class="mt-history-list">
                                <t t-foreach="history" t-as="entry">
                                    <div class="mt-history-item">
                                        <span class="mt-h-emoji">
                                            <t t-if="entry.mood == 'luar_biasa'">😄</t>
                                            <t t-elif="entry.mood == 'baik'">😊</t>
                                            <t t-elif="entry.mood == 'buruk'">😔</t>
                                            <t t-else="">😞</t>
                                        </span>
                                        <div class="mt-h-info">
                                            <div class="mt-h-mood" t-esc="mood_label[entry.mood]"/>
                                            <div class="mt-h-date" t-esc="entry.tanggal.strftime('%A, %d %B %Y')"/>
                                        </div>
                                        <t t-if="entry.tanggal == today">
                                            <span class="mt-h-badge">Hari ini</span>
                                        </t>
                                    </div>
                                </t>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="mt-empty">
                                <p>Belum ada riwayat mood. Mulai catat hari ini!</p>
                            </div>
                        </t>
                    </div>

                </main>
            </div>
            <script>
                document.querySelectorAll('.mt-mood-btn').forEach(function(btn) {
                    btn.addEventListener('click', function() {
                        document.querySelectorAll('.mt-mood-btn').forEach(function(b) {
                            b.classList.remove('selected');
                        });
                        this.classList.add('selected');
                        var radio = this.querySelector('input[type="radio"]');
                        if (radio) radio.checked = true;
                    });
                });
            </script>
        </t>
    </template>
</odoo>