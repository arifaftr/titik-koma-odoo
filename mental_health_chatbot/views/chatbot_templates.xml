<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="chatbot_widget" name="Mental Health Chatbot">
        <xpath expr="//body" position="inside">
            <div id="mental-chatbot">
                <div class="chat-header">
                    Konseling AI Mahasiswa
                </div>
                <div class="chat-body" id="chat-body">
                </div>
                <div class="chat-footer">
                    <input type="text"
                           id="chat-input"
                           placeholder="Ceritakan perasaanmu..."/>
                    <button id="send-btn">
                        Kirim
                    </button>
                </div>
            </div>
        </xpath>
    </template>

    <template id="chatbot_dashboard" name="Mental Health Dashboard">
        &lt;!DOCTYPE html&gt;
        <html>
            <head>
                <title>Titik koma. - Mental Health Dashboard</title>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
                <!-- Import Google Fonts -->
                <link rel="preconnect" href="https://fonts.googleapis.com"/>
                <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin=""/>
                <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&amp;family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
                
                <!-- FontAwesome for icons -->
                <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
                
                <!-- Load Odoo assets for frontend (this gives us jQuery, RPC, etc.) -->
                <t t-call-assets="web.assets_frontend" t-css="true" t-js="true"/>
                <t t-call-assets="chatbot.assets_chatbot" t-css="true" t-js="true"/>
            </head>
            <body>
                <div id="mhc-chatbot-root">
                    <div class="dashboard mhc-dashboard-container">
                        <aside class="sidebar" id="sidebar">
                            <img src="/titikkoma/static/src/img/titikkomalogo1.png" alt="Titik Koma" class="logo"/>
                            <nav class="menu" style="margin-top: 30px;">
                                <div class="menu-title">Menu Utama</div>
                                <a href="/" class="menu-item"><span class="icon">🏠</span><span>Beranda</span></a>
                                <a href="/assessment/retry/4591d5f4-b6f7-4991-aab7-9fdae2847b7e" class="menu-item">
                                    <span class="icon">📋</span><span>Self Assessment</span>
                                </a>
                                <a href="/mood-tracker" class="menu-item">
                                    <span class="icon">📊</span><span>Mood Tracker</span>
                                </a>
                                <div class="menu-title" style="margin-top: 30px;">Dukungan</div>
                                <a href="/self-help-tools" class="menu-item">
                                    <span class="icon">📚</span><span>Self-Help Tools</span>
                                </a>
                                <a href="/chatbot" class="menu-item active">
                                    <span class="icon">🤖</span><span>Chatbot AI</span>
                                </a>
                                <a href="/konseling" class="menu-item">
                                    <span class="icon">💬</span><span>Konseling</span>
                                </a>
                            </nav>
                            <a href="/web/session/logout" class="menu-item logout-btn">
                                <span class="icon">⏻</span><span>Logout</span>
                            </a>
                        </aside>

                        <main class="main-content mhc-main-content">
                            <div class="mhc-tab-workspace">
                                <!-- Tab: Chat -->
                                <div class="mhc-tab-pane active" id="tab-chat">
                                    <div class="chat-workspace-layout-v2">
                                        <div class="chat-header-v2">
                                            <div class="chat-header-left">
                                                <div class="chat-header-avatar"></div>
                                                <div class="chat-header-text">
                                                    <h2>TiKo AI</h2>
                                                    <p><span class="online-dot"></span> saya di sini untuk mendengarkan</p>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="chat-body-v2" id="chat-conversation-log">
                                            <!-- Starter message based on mockup style -->
                                            <div class="mhc-message bot-message-row">
                                                <div class="bot-avatar-circle"></div>
                                                <div class="message-bubble-bot">
                                                    Halo! Saya adalah TiKo AI dari Titik koma. Saya di sini siap mendengarkan cerita dan perasaanmu hari ini.
                                                </div>
                                            </div>
                                        </div>

                                        <div class="chat-input-area-v2">
                                            <div class="chat-input-wrapper">
                                                <input type="text" id="chat-dashboard-input" placeholder="Type a message"/>
                                                <button id="chat-dashboard-send" class="send-button-v2">
                                                    <i class="fa-solid fa-paper-plane"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Tab: Assessment -->
                                <div class="mhc-tab-pane" id="tab-assessment">
                                    <div class="assessment-container">
                                        <div class="assessment-card" id="quiz-intro">
                                            <div class="assessment-header">
                                                <i class="fa-solid fa-clipboard-list assessment-icon"></i>
                                                <h2>Self-Assessment Kesehatan Mental</h2>
                                                <p>Kenali kondisi emosionalmu lebih awal. Kuis ini dirancang untuk mendeteksi tingkat stres dan kecemasan mahasiswa secara umum.</p>
                                            </div>
                                            <div class="assessment-instructions">
                                                <h4>Petunjuk Pengisian:</h4>
                                                <ul>
                                                    <li>Jawab pertanyaan dengan jujur berdasarkan apa yang kamu rasakan dalam 1 minggu terakhir.</li>
                                                    <li>Kuis ini terdiri dari 7 pertanyaan pilihan ganda.</li>
                                                    <li>Hasil kuis ini bukan diagnosis klinis resmi, melainkan indikasi awal kondisi emosionalmu.</li>
                                                </ul>
                                            </div>
                                            <button class="btn btn-start-quiz" id="btn-start-quiz-action">Mulai Kuis</button>
                                        </div>

                                        <!-- Quiz Question Card -->
                                        <div class="assessment-card mhc-d-none" id="quiz-question-box">
                                            <div class="quiz-progress-bar">
                                                <div class="quiz-progress-fill" id="quiz-progress-fill" style="width: 14%;"></div>
                                            </div>
                                            <div class="quiz-header">
                                                <span class="question-number" id="question-number">Pertanyaan 1 dari 7</span>
                                                <h3 class="question-text" id="question-text">Apakah Anda merasa sulit untuk bersantai atau menenangkan diri akhir-akhir ini?</h3>
                                            </div>
                                            <div class="quiz-options">
                                                <button class="btn btn-quiz-option" data-score="0">Tidak pernah</button>
                                                <button class="btn btn-quiz-option" data-score="1">Jarang sekali</button>
                                                <button class="btn btn-quiz-option" data-score="2">Sering merasa demikian</button>
                                                <button class="btn btn-quiz-option" data-score="3">Hampir setiap hari</button>
                                            </div>
                                        </div>

                                        <!-- Quiz Results Card -->
                                        <div class="assessment-card mhc-d-none" id="quiz-results-box">
                                            <div class="assessment-header">
                                                <i class="fa-solid fa-circle-check results-success-icon"></i>
                                                <h2>Hasil Penilaian Anda</h2>
                                                <p>Berikut adalah ringkasan hasil kondisi emosional Anda:</p>
                                            </div>
                                            
                                            <div class="results-score-panel">
                                                <div class="gauge-score-value" id="results-score-value">12 / 21</div>
                                                <div class="gauge-status-label" id="results-status-label">Stres Sedang</div>
                                            </div>

                                            <div class="results-recommendations">
                                                <h4>Rekomendasi Kami:</h4>
                                                <p id="results-rec-text">Anda terindikasi memiliki tingkat stres sedang. Kami menyarankan Anda untuk mencoba teknik pernapasan di tab "Self-Help Tools" atau meluangkan waktu bercerita dengan Chat AI kami.</p>
                                            </div>

                                            <div class="results-actions">
                                                <button class="btn btn-retry-quiz" id="btn-retry-quiz-action"><i class="fa-solid fa-rotate-left"></i> Ulangi Kuis</button>
                                                <button class="btn btn-go-chat" data-target-tab="chat"><i class="fa-solid fa-comment"></i> Cerita dengan AI</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Tab: Self-Help Tools -->
                                <div class="mhc-tab-pane" id="tab-tools">
                                    <div class="tools-layout-grid">
                                        
                                        <!-- Tool 1: Interactive Breathing Exercise -->
                                        <div class="tool-card breathing-card">
                                            <div class="tool-card-header">
                                                <i class="fa-solid fa-wind tool-icon"></i>
                                                <h3>Latihan Pernapasan (Box Breathing)</h3>
                                                <p>Membantu meredakan kecemasan dan stres secara instan dengan memfokuskan pikiran Anda pada napas.</p>
                                            </div>
                                            
                                            <div class="breathing-interactive-box">
                                                <div class="breathing-circle-outer">
                                                    <div class="breathing-circle" id="breathing-bubble"></div>
                                                    <div class="breathing-timer-text" id="breathing-status">Mulai</div>
                                                </div>
                                            </div>
                                            
                                            <div class="breathing-controls">
                                                <button class="btn btn-start-breathing" id="btn-breathing-control">Mulai Latihan</button>
                                            </div>
                                        </div>

                                        <!-- Tool 2: Expandable Tips for Students -->
                                        <div class="tool-card tips-card">
                                            <div class="tool-card-header">
                                                <i class="fa-solid fa-lightbulb tool-icon"></i>
                                                <h3>Tips Mengelola Kesehatan Mental</h3>
                                                <p>Berikut adalah tips praktis harian untuk membantu Anda tetap seimbang menghadapi tuntutan kuliah.</p>
                                            </div>
                                            
                                            <div class="tips-accordion">
                                                <div class="mhc-accordion-item">
                                                    <button class="mhc-accordion-header">
                                                        <span>1. Atur Batas Waktu Belajar (Timebox)</span>
                                                        <i class="fa-solid fa-chevron-right mhc-arrow"></i>
                                                    </button>
                                                    <div class="mhc-accordion-body">
                                                        Jangan memaksakan diri belajar berjam-jam tanpa jeda. Gunakan teknik Pomodoro (25 menit belajar, 5 menit istirahat) untuk mencegah kelelahan otak (burnout).
                                                    </div>
                                                </div>

                                                <div class="mhc-accordion-item">
                                                    <button class="mhc-accordion-header">
                                                        <span>2. Batasi Paparan Media Sosial</span>
                                                        <i class="fa-solid fa-chevron-right mhc-arrow"></i>
                                                    </button>
                                                    <div class="mhc-accordion-body">
                                                        Membandingkan diri dengan pencapaian orang lain di media sosial sering kali meningkatkan kecemasan akademis. Berikan waktu detoks digital 1 jam sebelum tidur.
                                                    </div>
                                                </div>

                                                <div class="mhc-accordion-item">
                                                    <button class="mhc-accordion-header">
                                                        <span>3. Prioritaskan Kualitas Tidur</span>
                                                        <i class="fa-solid fa-chevron-right mhc-arrow"></i>
                                                    </button>
                                                    <div class="mhc-accordion-body">
                                                        Kurang tidur secara klinis memperburuk tingkat stres dan kecemasan. Usahakan tidur 7-8 jam per hari secara konsisten.
                                                    </div>
                                                </div>

                                                <div class="mhc-accordion-item">
                                                    <button class="mhc-accordion-header">
                                                        <span>4. Berbagi Cerita &amp; Cari Bantuan</span>
                                                        <i class="fa-solid fa-chevron-right mhc-arrow"></i>
                                                    </button>
                                                    <div class="mhc-accordion-body">
                                                        Membagikan apa yang kamu rasakan kepada sahabat, keluarga, atau Konselor AI kami bisa memberikan kelegaan emosional yang signifikan.
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Tool 3: Personal Journal / Reflection -->
                                        <div class="tool-card journal-card">
                                            <div class="tool-card-header">
                                                <i class="fa-solid fa-pen-nib tool-icon"></i>
                                                <h3>Refleksi Jurnal Harian</h3>
                                                <p>Menuliskan perasaan adalah salah satu terapi mengekspresikan emosi. Tuliskan apa yang kamu syukuri hari ini.</p>
                                            </div>
                                            
                                            <div class="journal-input-box">
                                                <textarea id="journal-text-input" placeholder="Tuliskan pikiranmu di sini..."></textarea>
                                                <div class="journal-footer-tools">
                                                    <div class="journal-mood-select">
                                                        <span>Mood:</span>
                                                        <select id="journal-mood-select-box">
                                                            <option value="&#129321; Amazing">&#129321; Amazing</option>
                                                            <option value="&#128578; Happy">&#128578; Happy</option>
                                                            <option value="&#128528; Neutral">&#128528; Neutral</option>
                                                            <option value="&#128546; Sad">&#128546; Sad</option>
                                                        </select>
                                                    </div>
                                                    <button class="btn btn-save-journal" id="btn-save-journal-entry">Simpan Jurnal</button>
                                                </div>
                                            </div>
                                            
                                            <div class="journal-history-list" id="journal-logs">
                                                <div class="journal-empty-msg">Belum ada jurnal yang disimpan hari ini.</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </main>
                    </div>

                <!-- Modals -->
                <!-- 1. Mood Picker Modal -->
                <div class="mhc-modal-backdrop mhc-d-none" id="mood-picker-modal">
                    <div class="mhc-custom-modal-box">
                        <div class="mhc-modal-header">
                            <h3>Bagaimana perasaanmu saat ini?</h3>
                            <button class="btn-close-modal" id="btn-close-mood-modal">&amp;times;</button>
                        </div>
                        <div class="mhc-modal-body mood-picker-body">
                            <div class="mood-selection-option" data-mood="Amazing" data-emoji="&#129321;">
                                <span class="mood-emoji-large">&#129321;</span>
                                <span class="mood-text-label">Amazing</span>
                            </div>
                            <div class="mood-selection-option" data-mood="Happy" data-emoji="&#128578;">
                                <span class="mood-emoji-large">&#128578;</span>
                                <span class="mood-text-label">Happy</span>
                            </div>
                            <div class="mood-selection-option" data-mood="Neutral" data-emoji="&#128528;">
                                <span class="mood-emoji-large">&#128528;</span>
                                <span class="mood-text-label">Neutral</span>
                            </div>
                            <div class="mood-selection-option" data-mood="Sad" data-emoji="&#128546;">
                                <span class="mood-emoji-large">&#128546;</span>
                                <span class="mood-text-label">Sad</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 2. Edit Profile Modal -->
                <div class="mhc-modal-backdrop mhc-d-none" id="edit-profile-modal">
                    <div class="mhc-custom-modal-box">
                        <div class="mhc-modal-header">
                            <h3>Edit Your Profile</h3>
                            <button class="btn-close-modal" id="btn-close-profile-modal">&amp;times;</button>
                        </div>
                        <div class="mhc-modal-body profile-edit-body">
                            <div class="mhc-form-group">
                                <label for="profile-input-name">Nama Lengkap</label>
                                <input type="text" id="profile-input-name" class="mhc-form-control" value="Arifa Fitra Salima"/>
                            </div>
                            
                            <div class="mhc-form-group">
                                <label>Pilih Avatar Profile</label>
                                <div class="avatar-selections">
                                    <div class="mhc-avatar-choice active" data-avatar="hijab">
                                        <div class="choice-circle hijab-circle"></div>
                                        <span>Hijab Avatar</span>
                                    </div>
                                    <div class="mhc-avatar-choice" data-avatar="boy">
                                        <div class="choice-circle boy-circle"></div>
                                        <span>Boy Avatar</span>
                                    </div>
                                    <div class="mhc-avatar-choice" data-avatar="girl">
                                        <div class="choice-circle girl-circle"></div>
                                        <span>Girl Avatar</span>
                                    </div>
                                </div>
                            </div>
                            
                            <button class="btn btn-save-profile-modal" id="btn-save-profile-modal-btn">Simpan Perubahan</button>
                        </div>
                    </div>
                </div>

                <!-- 3. Professional Counselor Contact Modal -->
                <div class="mhc-modal-backdrop mhc-d-none" id="counselor-modal">
                    <div class="mhc-custom-modal-box">
                        <div class="mhc-modal-header">
                            <h3>Layanan Konseling Kampus</h3>
                            <button class="btn-close-modal" id="btn-close-counselor-modal">&amp;times;</button>
                        </div>
                        <div class="mhc-modal-body counselor-body">
                            <div class="counselor-info-box">
                                <i class="fa-solid fa-user-doctor counselor-large-icon"></i>
                                <h4>Hubungi Layanan Konseling Mahasiswa</h4>
                                <p>Jika Anda membutuhkan bantuan, silakan hubungi tim psikolog dan konselor profesional kampus kami untuk sesi tatap muka maupun konseling online gratis.</p>
                            </div>
                            <div class="contact-details">
                                <div class="contact-line">
                                    <i class="fa-solid fa-phone"></i>
                                    <span>Hotline: +62 812-3456-7890</span>
                                </div>
                                <div class="contact-line">
                                    <i class="fa-solid fa-envelope"></i>
                                    <span>Email: konseling@kampus.ac.id</span>
                                </div>
                                <div class="contact-line">
                                    <i class="fa-solid fa-building-user"></i>
                                    <span>Gedung Rektorat Lt. 2, Ruang Konseling</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Chat Overlay -->
                <div id="mhc-chat-overlay" class="mhc-chat-overlay mhc-d-none">
                    <div class="chat-workspace-layout-v2">
                        <div class="chat-header-v2">
                            <div class="chat-header-left">
                                <div class="chat-header-avatar"></div>
                                <div class="chat-header-text">
                                    <h2>TiKo AI</h2>
                                    <p><span class="online-dot"></span> saya di sini untuk mendengarkan</p>
                                </div>
                            </div>
                        </div>
                        <div class="chat-body-v2" id="chat-conversation-log-overlay">
                            <div class="mhc-message bot-message-row">
                                <div class="bot-avatar-circle"></div>
                                <div class="message-bubble-bot">
                                    Halo! Saya adalah TiKo AI dari Titik koma. Saya di sini siap mendengarkan cerita dan perasaanmu hari ini.
                                </div>
                            </div>
                        </div>
                        <div class="chat-input-area-v2">
                            <div class="chat-input-wrapper">
                                <input type="text" id="chat-dashboard-input-overlay" placeholder="Type a message"/>
                                <button type="button" id="chat-dashboard-send-overlay" class="send-button-v2">
                                    <i class="fa-solid fa-paper-plane"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                </div>
            </body>
        </html>
    </template>

</odoo>

