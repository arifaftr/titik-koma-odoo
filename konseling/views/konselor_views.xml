<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_konselor_form" model="ir.ui.view">
        <field name="name">konseling.konselor.form</field>
        <field name="model">konseling.konselor</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="foto" widget="image" class="oe_avatar"/>
                    <group>
                        <field name="name"/>
                        <field name="spesialisasi"/>
                        <field name="nomor_wa"/>
                        <field name="aktif"/>
                    </group>
                    <field name="deskripsi"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_konselor_tree" model="ir.ui.view">
        <field name="name">konseling.konselor.tree</field>
        <field name="model">konseling.konselor</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="spesialisasi"/>
                <field name="nomor_wa"/>
                <field name="aktif"/>
            </tree>
        </field>
    </record>

    <record id="action_konselor" model="ir.actions.act_window">
        <field name="name">Data Konselor</field>
        <field name="res_model">konseling.konselor</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_konseling_root" name="Konseling" sequence="10"/>
    <menuitem id="menu_konselor" name="Data Konselor"
              parent="menu_konseling_root"
              action="action_konselor"/>
</odoo>